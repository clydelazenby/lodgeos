# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_STARTER_MONTHLY=price_...
STRIPE_STARTER_ANNUAL=price_...
STRIPE_PRO_MONTHLY=price_...
STRIPE_PRO_ANNUAL=price_...
STRIPE_DISTRICT_MONTHLY=price_...
STRIPE_DISTRICT_ANNUAL=price_...

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@lodgeos.com

# App
NEXT_PUBLIC_APP_URL=https://lodgeos.com
NEXT_PUBLIC_APP_NAME=LodgeOS
SUPER_ADMIN_EMAIL=clyde@lodgeos.com

# Anthropic (AI Secretary)
# Get a key at https://console.anthropic.com — powers the AI Secretary
# panel (minutes drafting + natural-language roster queries). Pricing at
# time of writing: Claude Sonnet 5 is $2/$10 per million input/output
# tokens (introductory rate through Aug 31 2026, then $3/$10). At
# realistic single-lodge usage this runs well under $1/month per lodge.
ANTHROPIC_API_KEY=sk-ant-...

# Cron authentication — required by /api/cron/* routes.
# Generate with: openssl rand -hex 32
# Set the same value as a header when configuring the scheduled trigger
# (Vercel Cron, Supabase pg_cron + pg_net, or any external scheduler).
CRON_SECRET=
